project_name     = "AEGIS"
environment      = "foundation-mvp"
aws_region       = "ap-south-1"
data_bucket_name = "aegis-bucket-data"

# Keep true for ephemeral MVP environments so destroy-all can remove the bucket
# even after IoT/S3 test objects and object versions are written.
data_bucket_force_destroy = true

ecr_edge_agent_repository_name         = "aegis/edge-agent"
ecr_edge_agent_image_tag_mutability    = "MUTABLE"
ecr_edge_agent_scan_on_push            = true
ecr_edge_agent_keep_sha_images         = 50
ecr_edge_agent_expire_untagged_days    = 7
